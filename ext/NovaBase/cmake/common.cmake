MACRO(NOVA_LINK_LIB)
    NOVA_PARSE_ARGUMENTS(ARG
        "DEBUG;RELEASE"
        ""
        ${ARGN}
    )
    LIST(GET ARG_DEFAULT_ARGS 0 TARGET)
    SET(LIBS ${ARG_DEFAULT_ARGS})
    LIST(REMOVE_AT LIBS 0)

    IF(ARG_DEBUG)
        FOREACH(_tmp ${ARG_DEBUG})
            SET(LIBS ${LIBS} debug ${_tmp})
        ENDFOREACH()
    ENDIF()

    TARGET_LINK_LIBRARIES(${TARGET} ${LIBS})
ENDMACRO()

MACRO(NOVA_INSTALL_PROJECT)
    ADD_CUSTOM_TARGET(Install${CMAKE_PROJECT_NAME}
        "${CMAKE_COMMAND}" --build "${CMAKE_BINARY_DIR}" --target install
        COMMENT "Install and Distribute ${CMAKE_PROJECT_NAME}")
ENDMACRO()

MACRO(NOVA_ADD_SUBDIRS)
    NOVA_GET_SUBDIRS(${CMAKE_CURRENT_SOURCE_DIR} tmp_subdirs)

    FOREACH(_base ${tmp_subdirs})
        IF(EXISTS "${_base}/CMakeLists.txt")
            ADD_SUBDIRECTORY(${_base})
        ENDIF()
    ENDFOREACH()
ENDMACRO()

MACRO(COPY_FILE_IF_EXISTS src dst)
    IF(EXISTS "${src}")
        CONFIGURE_FILE(${src} ${dst} COPYONLY)
    ENDIF()
ENDMACRO()

MACRO(ADD_DEPENDENCY_IF_EXISTS tgt dep)
    IF(TARGET "${dep}")
        ADD_DEPENDENCIES(${tgt} ${dep})
    ENDIF()
ENDMACRO()