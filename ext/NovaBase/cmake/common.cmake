SET(_CMAKE_DEEP 0)
SET(_CMAKE_DEEP_LIST)

MACRO(NOVA_CMAKE_ENTER)
    SET(_tmp ${CMAKE_CURRENT_LIST_DIR}/CMakeList.txt)

    IF(_tmp STREQUAL CMAKE_CURRENT_LIST_FILE)
        LIST(FIND _CMAKE_DEEP_LIST ${CMAKE_CURRENT_LIST_DIR} _index)

        IF(_index GREATER -1)
            NOVA_ERROR("The NOVA_CMAKE_ENTER() is called repeatedly.(${CMAKE_CURRENT_LIST_FILE})")
        ENDIF()

        IF(${CMAKE_CURRENT_LIST_FILE}_DEEP)
            NOVA_ERROR("The CMake File is called repeatedly.(${CMAKE_CURRENT_LIST_FILE})")
        ENDIF()

        NOVA_MESSAGE("CMAKE ENTER : ${CMAKE_CURRENT_LIST_FILE}")
        MATH(EXPR _CMAKE_DEEP "${_CMAKE_DEEP} + 1")
        SET(${CMAKE_CURRENT_LIST_FILE}_DEEP ON)
        LIST(INSERT _CMAKE_DEEP_LIST 0 ${CMAKE_CURRENT_LIST_DIR})
    ENDIF()
ENDMACRO()

MACRO(NOVA_CMAKE_LEAVE)
    SET(_tmp ${CMAKE_CURRENT_LIST_DIR}/CMakeList.txt)

    IF(_tmp STREQUAL CMAKE_CURRENT_LIST_FILE)
        LIST(FIND _CMAKE_DEEP_LIST ${CMAKE_CURRENT_LIST_DIR} _index)

        IF(_index EQUAL -1)
            NOVA_ERROR("The NOVA_CMAKE_LEAVE() is called repeatedly.(${CMAKE_CURRENT_LIST_FILE})")
        ELSE()
            NOVA_ERROR("The NOVA_CMAKE_ENTER() must be thre first called by an CMake File.(${CMAKE_CURRENT_LIST_FILE})")
        ENDIF()

        IF(_index GREATER 0)
            LIST(GET _CMAKE_DEEP_LIST 0 _tmp)
            NOVA_ERROR("The NOVA_CMAKE_LEAVE() has not been calledd in the end of CMake File.(${_tmp})")
        ENDIF()

        NOVA_MESSAGE("CMAKE LEAVE : ${CMAKE_CURRENT_LIST_FILE}")
        LIST(REMOVE_AT _CMAKE_DEEP_LIST 0)
        MATH(EXPR _CMAKE_DEEP "${_CMAKE_DEEP} - 1")
    ENDIF()
ENDMACRO()

MACRO(NOVA_ADD_LIB)
    NOVA_PARSE_ARGUMENTS(ARG
        "OUTPUT;HEADER;SOURCE;PACKAGE;PATH;INSTALL_DIR"
        "SHARE"
        ${ARGN}
    )

    IF(NOT ARG_DEFAULT_ARGS)
        MESSAGE(FATAL_ERROR "target cant empty.")
    ENDIF()

    IF(NOT ARG_HEADER AND NOT ARG_SOURCE)
        MESSAGE(FATAL_ERROR "To produce a library we need at least one source file.")
    ENDIF()

    LIST(GET ARG_DEFAULT_ARGS 0 TARGET)

    IF(NOT ARG_OUTPUT)
        SET(ARG_OUTPUT ${NOVA_LIB_DIR})
    ENDIF()

    ADD_LIBRARY(${TARGET} STATIC ${ARG_HEADER} ${ARG_SOURCE})
    TARGET_INCLUDE_DIRECTORIES(${TARGET} PRIVATE ${NOVA_COMMON_INC_DIRS})
    TARGET_LINK_LIBRARIES(${TARGET} ${ARG_PACKAGE})

    SET_TARGET_PROPERTIES(${TARGET} PROPERTIES ARCHIVE_OUTPUT_NAME_DEBUG ${ARG_OUTPUT}D)
    SET_TARGET_PROPERTIES(${TARGET} PROPERTIES ARCHIVE_OUTPUT_NAME_RELEASE ${ARG_OUTPUT})
    SET_TARGET_PROPERTIES(${TARGET} PROPERTIES ARCHIVE_OUTPUT_DIRECTORY_DEBUG ${ARG_PATH})
    SET_TARGET_PROPERTIES(${TARGET} PROPERTIES ARCHIVE_OUTPUT_DIRECTORY_RELEASE ${ARG_PATH})

    IF(ARG_SHARE AND CMAKE_SYSTEM_NAME MATCHES "Linux")
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES COMPILE_FLAGS
            "${CMAKE_SHARED_LIBRARY_C_FLAGS}")
    ENDIF()

    IF(NOT ARG_INSTALL_DIR)
        IF(${ARG_PATH} STREQUAL ${NOVA_LIB_DIR})
            INSTALL(TARGETS ${TRRGET}
                RUNTIME DESTINATION "${NOVA_INSTALL_DIR}/bin"
                LIBRARY DESTINATION "${NOVA_INSTALL_DIR}/lib"
                ARCHIVE DESTINATION "${NOVA_INSTALL_DIR}/lib"
            )
        ELSE()
            FILE(RELATIVE_PATH INSTALL_DIR ${NOVA_LIB_DIR} ${ARG_PATH})
            INSTALL(DIRECTORY ${ARG_PATH} DESTINATION ${NOVA_INSTALL_DIR}/lib)
        ENDIF()
    ELSE()
        IF(${ARG_INSTALL_DIR} STREQUAL "NULL")
        ELSE()
            INSTALL(TARGETS ${TARGET} DESTINATION ${ARG_INSTALL_DIR})
        ENDIF()
    ENDIF()
ENDMACRO()

MACRO(NOVA_ADD_DLL)
    NOVA_PARSE_ARGUMENTS(ARG
        "OUTPUT;HEADER;SOURCE;PACKAGE;PATH;INSTALL_DIR"
        "MODULE"
        ${ARGN}
    )

    IF(CMAKE_SYSTEM_NAME MATCHES "Windows")
        ADD_DEFINITIONS("-D_WIN_DLL_")
    ENDIF()

    IF(NOT ARG_HEADER AND NOT ARG_SOURCE)
        MESSAGE(FATAL_ERROR "To produce a library we need at least one source file.")
    ENDIF()

    LIST(GET ARG_DEFAULT_ARGS 0 TARGET)

    IF(NOT ARG_OUTPUT)
        SET(ARG_OUTPUT ${TARGET})
    ENDIF()

    IF(NOT ARG_PATH)
        SET(ARG_PATH ${NOVA_LIB_DIR})
    ENDIF()

    ADD_LIBRARY(${TARGET} SHARED ${ARG_HEADER} ${ARG_SOURCE})
    TARGET_INCLUDE_DIRECTORIES(${TARGET} PRIVATE ${NOVA_COMMON_INC_DIRS})
    TARGET_LINK_LIBRARIES(${TARGET} ${ARG_PACKAGE})

    IF(CMAKE_SYSTEM_NAME MATCHES "Windows")
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES RUNTIME_OUTPUT_NAME_DEBUG ${ARG_OUTPUT}D)
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES RUNTIME_OUTPUT_NAME_RELEASE ${ARG_OUTPUT})
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES RUNTIME_OUTPUT_DIRECTORY_DEBUG ${ARG_PATH})
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES RUNTIME_OUTPUT_DIRECTORY_RELEASE ${ARG_PATH})
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES ARCHIVE_OUTPUT_NAME_DEBUG ${ARG_OUTPUT}D)
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES ARCHIVE_OUTPUT_NAME_RELEASE ${ARG_OUTPUT})
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES ARCHIVE_OUTPUT_DIRECTORY_DEBUG ${ARG_PATH})
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES ARCHIVE_OUTPUT_DIRECTORY_RELEASE ${ARG_PATH})
    ELSEIF(CMAKE_SYSTEM_NAME MATCHES "Darwin")
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES LIBRARY_OUTPUT_NAME_DEBUG ${ARG_OUTPUT}D)
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES LIBRARY_OUTPUT_NAME_RELEASE ${ARG_OUTPUT})
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES LIBRARY_OUTPUT_DIRECTORY_DEBUG ${ARG_PATH})
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES LIBRARY_OUTPUT_DIRECTORY_RELEASE ${ARG_PATH})
    ELSEIF(CMAKE_SYSTEM_NAME MATCHES "Linux")
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES LIBRARY_OUTPUT_NAME_DEBUG ${ARG_OUTPUT}D)
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES LIBRARY_OUTPUT_NAME_RELEASE ${ARG_OUTPUT})
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES LIBRARY_OUTPUT_DIRECTORY_DEBUG ${ARG_PATH})
        SET_TARGET_PROPERTIES(${TARGET} PROPERTIES LIBRARY_OUTPUT_DIRECTORY_RELEASE ${ARG_PATH})
    ENDIF()

    IF(NOT ARG_INSTALL_DIR)
        IF(${ARG_PATH} STREQUAL ${NOVA_LIB_DIR})
            INSTALL(TARGETS ${TARGET}
                RUNTIME DESTINATION "${NOVA_INSTALL_DIR}/bin"
                LIBRARY DESTINATION "${NOVA_INSTALL_DIR}/lib"
                ARCHIVE DESTINATION "${NOVA_INSTALL_DIR}/lib"
            )
        ELSE()
            FILE(RELATIVE_PATH INSTALL_DIR ${NOVA_LIB_DIR} ${ARG_PATH})
            INSTALL(DIRECTORY ${ARG_PATH} DESTINATION ${NOVA_INSTALL_DIR}/lib)
        ENDIF()
    ELSE()
        IF(${ARG_INSTALL_DIR} STREQUAL "NULL")
        ELSE()
            INSTALL(TARGETS ${TARGET} DESTINATION ${ARG_INSTALL_DIR})
        ENDIF()
    ENDIF()
ENDMACRO()

