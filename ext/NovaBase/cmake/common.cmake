MACRO(NOVA_MESSAGE MSG)
    MESSAGE(STATUS ${MSG})
ENDMACRO()

MACRO(NOVA_WARNING MSG)
    MESSAGE(WARNING ${MSG})
ENDMACRO()

MACRO(NOVA_ERROR MSG)
    MESSAGE(FATAL_ERROR ${MSG})
ENDMACRO()

MACRO(NOVA_GET_HEADERS DIR HEADERS)
    FILE(GLOB _tmp_h "${DIR}/*.h")
    SET(${HEADERS} ${_tmp_h})
ENDMACRO()

MACRO(NOVA_GET_SOURCES DIR SOURCES)
    FILE(GLOB _tmp_cxx "${DIR}/*.c*")
    SET(${SOURCES} ${_tmp_cxx})
ENDMACRO()

MACRO(NOVA_GET_ALL_SOURCES DIR SOURCES)
    FILE(GLOB _tmp_h "${DIR}/*.h")
    FILE(GLOB _tmp_cxx "${DIR}/*.c*")
    SET(${SOURCES} "${_tmp_h};${_tmp_cxx}")
ENDMACRO()

MACRO(NOVA_GET_SUBDIRS DIR SUBDIRS)
    FILE(GLOB _tmp "${DIR}/*")
    SET(_subdirs "")

    FOREACH(_file ${_tmp})
        IF(IS_DIRECTORY ${_file})
            SET(_subdirs "${_subdirs};${_file}")
        ENDIF()
    ENDFOREACH()

    SET(${SUBDIRS} ${_subdirs})
ENDMACRO()

MACRO(NOVA_PARSE_ARGUMENTS prefix arg_names option_names)
    SET(DEFAULT_ARGS)

    FOREACH(arg_name ${arg_names})
        SET(${prefix}_${arg_name})
    ENDFOREACH(arg_name)

    FOREACH(option ${option_names})
        SET(${prefix}_${option} FALSE)
    ENDFOREACH(option)

    SET(currenct_arg_name DEFAULT_ARGS)
    SET(currenct_arg_list)

    FOREACH(arg ${ARGN})
        SET(larg_names ${arg_names})
        LIST(FIND larg_names "${arg}" is_arg_name)

        IF(is_arg_name GREATER -1)
            SET(${prefix}_${currenct_arg_name} ${currenct_arg_list})
            SET(currenct_arg_name ${arg})
            SET(currenct_arg_list)
        ELSE()
            SET(loption_names ${option_names})
            LIST(FIND loption_names "${arg}" is_option)

            IF(is_option GREATER -1)
                SET(${prefix}_${arg} TRUE)
            ELSE()
                SET(currenct_arg_list ${currenct_arg_list} ${arg})
            ENDIF(is_option GREATER -1)
        ENDIF(is_arg_name GREATER -1)
    ENDFOREACH(arg)

    SET(${prefix}_${currenct_arg_name} ${currenct_arg_list})
ENDMACRO()

MACRO(NOVA_GET_LIBS)
    NOVA_PARSE_ARGUMENTS(ARG "PATHS;NAMES" , "" , ${ARGN})

    IF(NOT ARG_DEFAULT_ARGS)
        MESSAGE(FATAL_ERROR "Dst cant empty")
    ENDIF()

    IF(NOT ARG_PATHS OR NOT ARG_NAMES)
        MESSAGE(FATAL_ERROR "Invalid arguments")
    ENDIF()

    SET(ret_libs "")

    FOREACH(tmp_lib ${ARG_NAMES})
        FIND_LIBRARY(ret_lib ${tmp_lib} PATHS ${ARG_PATHS} NO_DEFAULT_PATH)
        SET(ret_libs "${ret_libs};${ret_lib}")

        IF(ret_lib)
        ELSE()
            NOVA_ERROR("${tmp_lib} not found!")
        ENDIF()

        UNSET(ret_lib CACHE)
    ENDFOREACH()

    LIST(GET ARG_DEFAULT_ARGS 0 _target)
    SET(${_target} ${ret_libs})
ENDMACRO()

MACRO(NOVA_SET_COMMON_DIRECTORIES src_dir)
    SET(_tmp_inc_dir ${src_dir}/include)
    SET(_tmp_lib_dir ${src_dir}/lib)
    SET(NOVA_COMMON_INC_DIRS ${NOVA_COMMON_INC_DIRS} ${src_dir}/include)
    NOVA_GET_SUBDIRS(${_tmp_inc_dir} _subdirs)

    IF(_subdirs)
        SET(NOVA_COMMON_INC_DIRS ${NOVA_COMMON_INC_DIRS} ${_subdirs})
    ENDIF()

    IF(CMAKE_SYSTEM_NAME MATCHES "Windows")
        SET(NOVA_COMMON_LIB_DIRS ${NOVA_COMMON_LIB_DIRS} ${_tmp_lib_dir} ${_tmp_lib_dir}/win)
    ELSEIF(CMAKE_SYSTEM_NAME MATCHES "Linux")
        SET(NOVA_COMMON_LIB_DIRS ${NOVA_COMMON_LIB_DIRS} ${_tmp_lib_dir} ${_tmp_lib_dir}/linux)
    ENDIF()

    LINK_DIRECTORIES(${NOVA_COMMON_LIB_DIRS})
ENDMACRO()

